# Normalize all text files to LF in the repository.
* text=auto eol=lf

*.R text eol=lf
*.r text eol=lf
*.Rmd text eol=lf
*.rmd text eol=lf
*.Rnw text eol=lf
*.Rd text eol=lf
*.qmd text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.cff text eol=lf
